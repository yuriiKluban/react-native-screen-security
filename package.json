{
  "name": "react-native-screen-security",
  "version": "1.0.3",
  "description": "A high-performance React Native TurboModule providing native screen security, anti-screenshot protection, and seamless background blurring for iOS and Android.",
  "summary": "Native screen security and snapshot protection for React Native New Architecture",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "author": "Yurii Kluban <ykluban9@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/yuriikluban/react-native-screen-security#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuriikluban/react-native-screen-security.git"
  },
  "bugs": {
    "url": "https://github.com/yuriikluban/react-native-screen-security/issues"
  },
  "keywords": [
    "react-native",
    "turbo-module",
    "new-architecture",
    "screen-security",
    "screenshot",
    "screen-capture",
    "flag-secure",
    "privacy",
    "ios",
    "android"
  ],
  "files": [
    "src",
    "lib",
    "ios",
    "android",
    "react-native-screen-security.podspec",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build:types": "tsc",
    "build:js": "babel src --out-dir lib --extensions '.ts,.tsx'",
    "prepare": "rm -rf lib && yarn build:types && yarn build:js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"./**/*.{ts,tsx}\"",
    "format": "prettier --write \"./**/*.{ts,tsx,json,md}\""
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.79"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "react-native": "src/index.ts",
  "codegenConfig": {
    "name": "RTNScreenSecuritySpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativescreensecurity"
    },
    "ios": {
      "componentProvider": {
        "SecureView": "RTNSecureView"
      }
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.8.3",
    "react-native": "^0.85.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
